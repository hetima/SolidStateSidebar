<UserControl x:Class="SSS.Views.Components.ApplicationAddPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFDevelopers.Controls"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:res="clr-namespace:SSS"
             MinWidth="480"
             MinHeight="400"
             PreviewKeyDown="UserControl_PreviewKeyDown">
    <controls:SmallPanel>
        <Border Margin="8">
            <Border.Effect>
                <DropShadowEffect BlurRadius="8" ShadowDepth="2" Opacity="0.4" />
            </Border.Effect>
            <Border Background="{DynamicResource WD.BackgroundBrush}"
                    BorderBrush="{DynamicResource WD.BaseBrush}"
                    BorderThickness="1"
                    CornerRadius="4">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Bottom" Style="{StaticResource WindowButtons}">
                    <Button DockPanel.Dock="Bottom"
                            Content="{x:Static res:Strings.ButtonClose}"
                            Click="OkButton_Click"
                            HorizontalAlignment="Right"/>
                </StackPanel>
                <ListView x:Name="ProcessesListView"
                          MaxHeight="320"
                          Margin="16,16,16,0"
                          ItemContainerStyle="{StaticResource MonitorHardwareItem}"
                          Style="{StaticResource HardwareGrid}">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header=" " HeaderContainerStyle="{StaticResource MonitorHardwareHeaderCenter}" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type monitor:HardwareConfig}">
                                        <CheckBox IsChecked="{Binding Path=Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MonitorHardwareCheckbox}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="{x:Static res:Strings.SettingsChooseAppsColumn2}" HeaderContainerStyle="{StaticResource MonitorHardwareHeader}" Width="380">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type monitor:HardwareConfig}">
                                        <TextBlock Text="{Binding Path=ActualName, Mode=OneWay}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
            </Border>
        </Border>
    </controls:SmallPanel>
</UserControl>
