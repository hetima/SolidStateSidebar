<UserControl x:Class="SSS.Views.Components.MetricsSettingPopup"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:controls="clr-namespace:WPFDevelopers.Controls"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             xmlns:res="clr-namespace:SSS"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             MinWidth="500"
             MinHeight="200">
    <UserControl.Resources>
        <conv:MetricLabelDisplayConverter x:Key="LabelDisplayConverter" />
    </UserControl.Resources>
    <controls:SmallPanel>
        <Border Background="{DynamicResource WD.BackgroundBrush}"
                BorderBrush="{DynamicResource WD.BaseBrush}"
                BorderThickness="1"
                CornerRadius="4">
            <DockPanel LastChildFill="True">
                <StackPanel DockPanel.Dock="Bottom" Style="{StaticResource WindowButtons}">
                    <Button DockPanel.Dock="Bottom"
                            Content="{x:Static res:Strings.ButtonClose}"
                            Click="OkButton_Click"
                            HorizontalAlignment="Right"/>
                </StackPanel>
                <ListView ItemsSource="{Binding Path=Metrics, Mode=OneWay}"
                          MaxHeight="400"
                          Margin="16,16,16,0"
                          dd:DragDrop.IsDragSource="True"
                          dd:DragDrop.IsDropTarget="True"
                          ItemContainerStyle="{StaticResource MonitorHardwareItem}"
                          Style="{StaticResource HardwareGrid}">
                    <ListView.View>
                        <GridView AllowsColumnReorder="False">
                            <GridViewColumn Header=" " HeaderContainerStyle="{StaticResource MonitorHardwareHeaderCenter}" Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type monitor:MetricConfig}">
                                        <CheckBox IsChecked="{Binding Path=Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource MonitorHardwareCheckbox}" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Metrics" HeaderContainerStyle="{StaticResource MonitorHardwareHeader}" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type monitor:MetricConfig}">
                                        <TextBlock Text="{Binding Name, Mode=OneWay}" VerticalAlignment="Center" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Header="Label (Editable)" HeaderContainerStyle="{StaticResource MonitorHardwareHeader}" Width="160">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type monitor:MetricConfig}">
                                        <TextBox BorderThickness="0" Padding="2,0">
                                            <TextBox.Text>
                                                <MultiBinding Converter="{StaticResource LabelDisplayConverter}"
                                                              Mode="TwoWay"
                                                              UpdateSourceTrigger="LostFocus">
                                                    <Binding Path="Label" Mode="TwoWay" />
                                                    <Binding Path="ActualLabel" Mode="OneWay" />
                                                </MultiBinding>
                                            </TextBox.Text>
                                        </TextBox>
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                            <GridViewColumn Width="40">
                                <GridViewColumn.CellTemplate>
                                    <DataTemplate DataType="{x:Type monitor:MetricConfig}">
                                        <Button Content="&#x21BA;" Style="{StaticResource MonitorHardwareResetButton}" ToolTip="Reset label" Click="MetricResetButton_Click" />
                                    </DataTemplate>
                                </GridViewColumn.CellTemplate>
                            </GridViewColumn>
                        </GridView>
                    </ListView.View>
                </ListView>
            </DockPanel>
        </Border>
    </controls:SmallPanel>
</UserControl>
