<Window x:Class="SSS.Features.EditShortcutKey.EditShortcutKeyView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:SSS.Features.EditShortcutKey"
        xmlns:res="clr-namespace:SSS"
        mc:Ignorable="d"
        Title="{Binding ActionName}"
        Width="340"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontSize="14"
        d:DataContext="{d:DesignInstance local:EditShortcutKeyViewModel}">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </Window.Resources>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="8" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="16" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- アクション名 -->
        <TextBlock Grid.Row="0"
                   Text="{Binding ActionName}"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap" />

        <!-- ショートカット入力表示 -->
        <TextBox Grid.Row="2"
                 x:Name="ShortcutInputTextBox"
                 Text="{Binding DisplayString, Mode=OneWay}"
                 IsReadOnly="True"
                 FontFamily="Consolas"
                 FontSize="16"
                 TextAlignment="Center"
                 Padding="8,6"
                 PreviewKeyDown="ShortcutInputTextBox_PreviewKeyDown" />

        <!-- 警告メッセージ -->
        <TextBlock Grid.Row="4"
                   Text="{Binding WarningMessage}"
                   Foreground="OrangeRed"
                   TextWrapping="Wrap">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding WarningMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <!-- 競合ショートカット削除ボタン -->
        <Button Grid.Row="6"
                Content="{x:Static res:Strings.EditShortcutKeyRemoveConflict}"
                Command="{Binding RemoveConflictingShortcutCommand}"
                Visibility="{Binding ShortcutConflicted, Converter={StaticResource BoolToVisibility}}" />

        <!-- 操作ボタン -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <StackPanel.Resources>
                <Style TargetType="Button">
                    <Setter Property="MinWidth" Value="72" />
                    <Setter Property="Margin" Value="8,0,0,0" />
                </Style>
            </StackPanel.Resources>
            <Button Content="{x:Static res:Strings.EditShortcutKeyClear}"
                    Command="{Binding ClearCommand}" />
            <Button Content="{x:Static res:Strings.EditShortcutKeyCancel}"
                    Command="{Binding CloseCommand}" />
            <Button Content="{x:Static res:Strings.EditShortcutKeySet}"
                    Command="{Binding SaveCommand}" />
        </StackPanel>
    </Grid>
</Window>
