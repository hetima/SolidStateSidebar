<UserControl x:Class="SSS.Module.WindowMonitor.SettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             xmlns:res="clr-namespace:SSS"
             xmlns:components="clr-namespace:SSS.Views.Components"
             xmlns:app="clr-namespace:SSS"
             mc:Ignorable="d">
    <Border Style="{StaticResource MonitorDetailsBorder}">
        <StackPanel Style="{StaticResource VerticalPanel}">

            <!-- Header Style -->
            <StackPanel Orientation="Horizontal"
                        Margin="0,0,0,10">
                <Label Content="{x:Static res:Strings.SettingsHeaderStyle}"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       Padding="0"/>
                <ComboBox ItemsSource="{StaticResource SectionHeaderStyleItems}"
                          SelectedValue="{Binding Path=SectionHeaderStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="."
                          ItemTemplate="{StaticResource SectionHeaderStyleItemTemplate}"/>
            </StackPanel>

            <!-- Font Name -->
            <StackPanel Orientation="Horizontal"
                    Margin="0,0,0,10">
                <Label Content="{x:Static res:Strings.SettingsFontName}"
                        VerticalAlignment="Center"
                        Margin="0,0,10,0"
                        Padding="0"/>
                <ComboBox ItemsSource="{x:Static app:App.FontNameItems}"
                          SelectedValue="{Binding Path=FontName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ToolTip="{x:Static res:Strings.SettingsFontNameTooltip}"/>
            </StackPanel>

            <!-- Font Size -->
            <StackPanel Margin="0,0,10,10">
                <Label Content="{x:Static res:Strings.SettingsFontSize}"
                       Margin="0,5,0,0"
                       ToolTip="{x:Static res:Strings.SettingsFontSizeTooltip}"/>
                <DockPanel Margin="0,0,0,5">
                    <TextBox Text="{Binding ElementName=FontSizeSlider, Path=Value, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="NumberBox_PreviewTextInput"
                             Style="{StaticResource SettingInput}"
                             Width="50"
                             DockPanel.Dock="Right"/>
                    <Slider x:Name="FontSizeSlider"
                            Style="{StaticResource SettingSlider}"
                            Value="{Binding Path=FontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="0"
                            Maximum="40"
                            TickFrequency="1"
                            LargeChange="1"
                            IsSnapToTickEnabled="True"
                            ToolTip="{x:Static res:Strings.SettingsFontSizeTooltip}"/>
                </DockPanel>
            </StackPanel>


            <!-- Max Display Count -->
            <StackPanel Margin="0,10,10,10">
                <Label Content="{x:Static res:Strings.SettingsMaxDisplayCount}"
                       Margin="0,5,0,0"
                       ToolTip="{x:Static res:Strings.SettingsMaxDisplayCountTooltip}"/>
                <DockPanel Margin="0,0,0,5">
                    <TextBox Text="{Binding ElementName=MaxDisplayCountSlider, Path=Value, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="NumberBox_PreviewTextInput"
                             Style="{StaticResource SettingInput}"
                             Width="50"
                             DockPanel.Dock="Right"/>
                    <Slider x:Name="MaxDisplayCountSlider"
                            Style="{StaticResource SettingSlider}"
                            Value="{Binding Path=MaxDisplayCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="0"
                            Maximum="24"
                            TickFrequency="1"
                            LargeChange="1"
                            ToolTip="{x:Static res:Strings.SettingsMaxDisplayCountTooltip}"/>
                </DockPanel>
            </StackPanel>

            <!-- Applications Label -->
            <DockPanel LastChildFill="False"
                    Margin="0,10,0,5">
                <Label Content="{x:Static res:Strings.SettingsApplications}"
                        VerticalAlignment="Center"/>
                <Button Name="AddButton"
                        Content="{x:Static res:Strings.SettingsApplicationAdd}"
                        Margin="10,0,0,0"
                        Padding="8,2"
                        VerticalAlignment="Center"
                        Click="AddButton_Click"
                        ToolTip="{x:Static res:Strings.SettingsApplicationAddTooltip}"/>
            </DockPanel>
            <!-- Application List -->
            <components:ApplicationListView/>
            <!-- Application Add Popup -->
            <Popup x:Name="ApplicationPopup"
                   StaysOpen="False"
                   AllowsTransparency="True"
                   PopupAnimation="Fade">
                <components:ApplicationAddPopup x:Name="ApplicationAddPopupCtrl"
                        CloseRequested="ApplicationPopup_CloseRequested"/>
            </Popup>
            
        </StackPanel>
    </Border>
</UserControl>
