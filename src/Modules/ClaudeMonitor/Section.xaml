<UserControl x:Class="SSS.Module.ClaudeMonitor.Section"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:core="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:MetricLabelConverter x:Key="MetricLabelConverter" />
    </UserControl.Resources>
    <StackPanel Style="{StaticResource GroupPanel}">
        <!-- カスタムヘッダー：アイコン + ラベル + 更新ボタン -->
        <StackPanel x:Name="HeaderPanel" Style="{StaticResource ModuleTitle}">
            <Image x:Name="IconImage" Style="{StaticResource AppIconImage}" />
            <Label Content="Claude" Style="{StaticResource AppTitle}"
                   Foreground="{Binding Source={x:Static core:Settings.Instance}, Path=FontColor, Mode=OneWay}" />
            <Button x:Name="RefreshButton" Click="RefreshButton_Click"
                    Style="{StaticResource IconButton}"
                    Width="14" Height="14" Margin="6,0,0,0"
                    ToolTip="更新">
                <TextBlock Text="&#xE72C;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                           Foreground="{Binding Source={x:Static core:Settings.Instance}, Path=FontColor, Mode=OneWay}" />
            </Button>
        </StackPanel>

        <!-- メトリクス表示 -->
        <ItemsControl ItemsSource="{Binding Path=Monitors, Mode=OneWay}">
            <ItemsControl.Resources>
                <DataTemplate DataType="{x:Type core:BaseMonitor}">
                    <StackPanel Style="{StaticResource MonitorPanel}">
                        <ItemsControl ItemsSource="{Binding Path=Metrics, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type core:iMetric}">
                                    <DockPanel Style="{StaticResource MetricPanel}">
                                        <TextBlock Text="{Binding Path=Label, Mode=OneWay, Converter={StaticResource MetricLabelConverter}}" Style="{StaticResource MetricLabel}" />
                                        <TextBlock Text="{Binding Path=Text, Mode=OneWay}" Style="{StaticResource MetricValue}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Style="{StaticResource VerticalPanel}" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.Resources>
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Style="{StaticResource VerticalPanel}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
        </ItemsControl>
    </StackPanel>
</UserControl>
