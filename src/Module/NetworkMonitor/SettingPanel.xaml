<UserControl x:Class="SSS.Module.NetworkMonitor.SettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             xmlns:res="clr-namespace:SSS"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:IntToStringConverter x:Key="IntConverter" />
        <x:Array x:Key="SectionHeaderStyleItems" Type="monitor:SectionHeaderStyle">
            <monitor:SectionHeaderStyle>Default</monitor:SectionHeaderStyle>
            <monitor:SectionHeaderStyle>Small</monitor:SectionHeaderStyle>
            <monitor:SectionHeaderStyle>None</monitor:SectionHeaderStyle>
        </x:Array>
    </UserControl.Resources>
    <Border Style="{StaticResource MonitorDetailsBorder}">
        <StackPanel Style="{StaticResource VerticalPanel}">
            <!-- Header Style -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Header Style" VerticalAlignment="Center" Margin="0,0,10,0" Padding="0" />
                <ComboBox ItemsSource="{StaticResource SectionHeaderStyleItems}"
                          SelectedValue="{Binding Path=SectionHeaderStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="." />
            </StackPanel>

            <!-- Hardware List -->
            <ListView ItemsSource="{Binding Path=HardwareOC, Mode=OneWay}"
                      dd:DragDrop.IsDragSource="True"
                      dd:DragDrop.IsDropTarget="True"
                      ItemContainerStyle="{StaticResource MonitorHardwareItem}"
                      Style="{StaticResource HardwareGrid}">
                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <GridViewColumn Header="{x:Static res:Strings.SettingsHardwareColumn1}" HeaderContainerStyle="{StaticResource MonitorHardwareHeaderCenter}">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type monitor:HardwareConfig}">
                                    <CheckBox IsChecked="{Binding Path=Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsHardwareEnabledTooltip}" Style="{StaticResource MonitorHardwareCheckbox}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="{x:Static res:Strings.SettingsHardwareColumn2}" HeaderContainerStyle="{StaticResource MonitorHardwareHeader}" Width="230">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type monitor:HardwareConfig}">
                                    <TextBox Text="{Binding Path=Name, Mode=TwoWay}" Style="{StaticResource MonitorHardwareText}" ToolTip="{x:Static res:Strings.SettingsHardwareNameTooltip}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate DataType="{x:Type monitor:HardwareConfig}">
                                    <Button Content="&#x21BA;" Style="{StaticResource MonitorHardwareResetButton}" ToolTip="Reset name" Click="HardwareResetButton_Click" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>

            <!-- Metrics -->
            <DockPanel LastChildFill="True" Margin="0,15,0,0">
                <Label DockPanel.Dock="Left" Content="{x:Static res:Strings.SettingsMetrics}" Margin="0,0,10,0" />
                <xctk:CheckComboBox ItemsSource="{Binding Path=Metrics, Mode=OneWay}" DisplayMemberPath="Name" SelectedMemberPath="Enabled" Delimiter=", " ToolTip="{x:Static res:Strings.SettingsMetricsTooltip}" />
            </DockPanel>

            <!-- Params -->
            <StackPanel Margin="10">
                <CheckBox Content="{x:Static res:Strings.SettingsShowHardwareNames}" IsChecked="{Binding Path=ShowHardwareNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsShowHardwareNamesTooltip}" />
                <CheckBox Content="{x:Static res:Strings.SettingsRoundAllDecimals}" IsChecked="{Binding Path=RoundAll, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsRoundAllDecimalsTooltip}" />
                <CheckBox Content="{x:Static res:Strings.SettingsUseBytesPerSecond}" IsChecked="{Binding Path=UseBytes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsUseBytesPerSecondTooltip}" />
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="{x:Static res:Strings.SettingsBandwidthInAlert}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Padding="0"/>
                    <TextBox Text="{Binding Path=BandwidthInAlert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntConverter}}"
                            ToolTip="{x:Static res:Strings.SettingsBandwidthInAlertTooltip}"
                            VerticalAlignment="Center"
                            Width="40"
                            MaxLines="1"
                             Style="{StaticResource SettingInput}"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal"
                        Margin="0,5">
                    <Label Content="{x:Static res:Strings.SettingsBandwidthOutAlert}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Padding="0"/>
                    <TextBox Text="{Binding Path=BandwidthOutAlert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntConverter}}"
                            ToolTip="{x:Static res:Strings.SettingsBandwidthOutAlertTooltip}"
                            VerticalAlignment="Center"
                            Width="40"
                            MaxLines="1"
                             Style="{StaticResource SettingInput}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
