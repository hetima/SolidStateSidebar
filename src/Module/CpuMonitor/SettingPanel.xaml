<UserControl x:Class="SSS.Module.CpuMonitor.SettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:dd="clr-namespace:GongSolutions.Wpf.DragDrop;assembly=GongSolutions.Wpf.DragDrop"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             xmlns:res="clr-namespace:SSS"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             xmlns:styling="clr-namespace:SSS.Styling"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:IntToStringConverter x:Key="IntConverter" />
        <x:Array x:Key="SectionHeaderStyleItems" Type="monitor:SectionHeaderStyle">
            <monitor:SectionHeaderStyle>Default</monitor:SectionHeaderStyle>
            <monitor:SectionHeaderStyle>Small</monitor:SectionHeaderStyle>
            <monitor:SectionHeaderStyle>None</monitor:SectionHeaderStyle>
        </x:Array>
    </UserControl.Resources>
    <Border Style="{StaticResource MonitorDetailsBorder}">
        <StackPanel Style="{StaticResource VerticalPanel}">
            <!-- Header Style -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Label Content="Header Style" VerticalAlignment="Center" Margin="0,0,10,0" Padding="0" />
                <ComboBox ItemsSource="{StaticResource SectionHeaderStyleItems}"
                          SelectedValue="{Binding Path=SectionHeaderStyle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="." />
            </StackPanel>

            <!-- Hardware List -->
            <styling:HardwareListView />

            <!-- Metrics -->
            <DockPanel LastChildFill="True" Margin="0,15,0,0">
                <Label DockPanel.Dock="Left" Content="{x:Static res:Strings.SettingsMetrics}" Margin="0,0,10,0" />
                <xctk:CheckComboBox ItemsSource="{Binding Path=Metrics, Mode=OneWay}" DisplayMemberPath="Name" SelectedMemberPath="Enabled" Delimiter=", " ToolTip="{x:Static res:Strings.SettingsMetricsTooltip}" />
            </DockPanel>

            <!-- Params -->
            <StackPanel Margin="10">
                <CheckBox Content="{x:Static res:Strings.SettingsShowHardwareNames}" IsChecked="{Binding Path=ShowHardwareNames, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsShowHardwareNamesTooltip}" />
                <CheckBox Content="{x:Static res:Strings.SettingsRoundAllDecimals}" IsChecked="{Binding Path=RoundAll, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsRoundAllDecimalsTooltip}" />
                <CheckBox Content="{x:Static res:Strings.SettingsAllCoreClocks}" IsChecked="{Binding Path=AllCoreClocks, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsAllCoreClocksTooltip}" />
                <CheckBox Content="{x:Static res:Strings.SettingsUseGHz}" IsChecked="{Binding Path=UseGHz, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsUseGHzTooltip}" />
                <CheckBox Content="{x:Static res:Strings.SettingsUseFahrenheit}" IsChecked="{Binding Path=UseFahrenheit, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.SettingsUseFahrenheitTooltip}" />
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="{x:Static res:Strings.SettingsTemperatureAlert}" VerticalAlignment="Center" Margin="0,0,10,0" Padding="0" />
                    <TextBox Text="{Binding Path=TempAlert, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource IntConverter}}"
                            ToolTip="{x:Static res:Strings.SettingsTemperatureAlertTooltip}"
                            VerticalAlignment="Center"
                            Width="40"
                            MaxLines="1"
                             Style="{StaticResource SettingInput}"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
