<UserControl x:Class="SSS.Module.TimeMonitor.SettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             xmlns:res="clr-namespace:SSS"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:xctk="http://schemas.xceed.com/wpf/xaml/toolkit"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:DateFormatConverter x:Key="DateFormatConverter" />
        <conv:DateFormatDisplayConverter x:Key="DateFormatDisplayConverter" />
        <conv:IntToStringConverter x:Key="IntConverter" />

        <!-- DateFormat ComboBox items -->
        <x:Array x:Key="DateFormatItems" Type="sys:Int32">
            <sys:Int32>0</sys:Int32>
            <sys:Int32>1</sys:Int32>
            <sys:Int32>2</sys:Int32>
            <sys:Int32>3</sys:Int32>
        </x:Array>

        <DataTemplate x:Key="DateFormatItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource DateFormatDisplayConverter}}" />
        </DataTemplate>
    </UserControl.Resources>
    <Border Style="{StaticResource MonitorDetailsBorder}">
        <StackPanel Style="{StaticResource VerticalPanel}">
            <!-- Metrics -->
            <DockPanel LastChildFill="True" Margin="0,0,0,0">
                <Label DockPanel.Dock="Left" Content="{x:Static res:Strings.SettingsMetrics}" Margin="0,0,10,0" />
                <xctk:CheckComboBox ItemsSource="{Binding Path=Metrics, Mode=OneWay}" DisplayMemberPath="Name" SelectedMemberPath="Enabled" Delimiter=", " ToolTip="{x:Static res:Strings.SettingsMetricsTooltip}" />
            </DockPanel>

            <!-- Params: Clock24HR (Boolean), DateFormat (ComboBox) -->
            <StackPanel Margin="10">
                <CheckBox Content="{x:Static res:Strings.Settings24HourClock}" IsChecked="{Binding Path=Clock24HR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" ToolTip="{x:Static res:Strings.Settings24HourClockTooltip}" />
                <StackPanel Orientation="Horizontal" Margin="0,5">
                    <Label Content="{x:Static res:Strings.SettingsDateFormat}" VerticalAlignment="Center" Margin="0,0,10,0" Padding="0" />
                    <ComboBox ItemsSource="{StaticResource DateFormatItems}"
                              SelectedValue="{Binding Path=DateFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DateFormatConverter}}"
                              SelectedValuePath="."
                              ItemTemplate="{StaticResource DateFormatItemTemplate}"
                              ToolTip="{x:Static res:Strings.SettingsDateFormatTooltip}" />
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
