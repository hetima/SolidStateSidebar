<UserControl x:Class="SSS.Module.TimeMonitor.SettingPanel"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:monitor="clr-namespace:SSS.Core"
             xmlns:conv="clr-namespace:SSS.Converters"
             xmlns:res="clr-namespace:SSS"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             mc:Ignorable="d">
    <UserControl.Resources>
        <conv:DateFormatConverter x:Key="DateFormatConverter" />
        <conv:DateFormatDisplayConverter x:Key="DateFormatDisplayConverter" />
        <conv:IntToStringConverter x:Key="IntConverter" />

        <!-- DateFormat ComboBox items -->
        <x:Array x:Key="DateFormatItems" Type="sys:Int32">
            <sys:Int32>0</sys:Int32>
            <sys:Int32>1</sys:Int32>
            <sys:Int32>2</sys:Int32>
            <sys:Int32>3</sys:Int32>
        </x:Array>

        <DataTemplate x:Key="DateFormatItemTemplate">
            <TextBlock Text="{Binding Converter={StaticResource DateFormatDisplayConverter}}" />
        </DataTemplate>
    </UserControl.Resources>
    <Border Style="{StaticResource MonitorDetailsBorder}">
        <StackPanel Style="{StaticResource VerticalPanel}">
            <!-- Show Date / Show Time -->
            <CheckBox Content="Show Date" IsChecked="{Binding Path=ShowDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            <StackPanel Margin="30,10,10,10">
                <Label Content="Date Font Size"
                        Margin="0,5,0,0"
                        ToolTip="Adjust the font size for the date display (10-40)"/>
                <DockPanel Margin="0,0,0,5">
                    <TextBox Text="{Binding ElementName=DateFontSizeSlider, Path=Value, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="NumberBox_PreviewTextInput"
                             Style="{StaticResource SettingInput}"
                             Width="50"
                             DockPanel.Dock="Right"/>
                    <Slider x:Name="DateFontSizeSlider"
                            Style="{StaticResource SettingSlider}"
                            Value="{Binding Path=DateFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="10"
                            Maximum="40"
                            TickFrequency="1"
                            LargeChange="5"
                            ToolTip="Adjust the font size for the date display (10-40)"/>
                </DockPanel>
                <StackPanel Orientation="Horizontal"
                        Margin="0,5">
                    <Label Content="{x:Static res:Strings.SettingsDateFormat}"
                            VerticalAlignment="Center"
                            Margin="0,0,10,0"
                            Padding="0"/>
                    <ComboBox ItemsSource="{StaticResource DateFormatItems}"
                              SelectedValue="{Binding Path=DateFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DateFormatConverter}}"
                              SelectedValuePath="."
                              ItemTemplate="{StaticResource DateFormatItemTemplate}"
                              ToolTip="{x:Static res:Strings.SettingsDateFormatTooltip}"/>
                </StackPanel>
            </StackPanel>
            <CheckBox Content="Show Time" IsChecked="{Binding Path=ShowTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <StackPanel Margin="30,10,10,10">
  
                <Label Content="Time Font Size" Margin="0,5,0,0" ToolTip="Adjust the font size for the time display (10-40)" />
                <DockPanel Margin="0,0,0,5">
                    <TextBox Text="{Binding ElementName=TimeFontSizeSlider, Path=Value, UpdateSourceTrigger=PropertyChanged}"
                             PreviewTextInput="NumberBox_PreviewTextInput"
                             Style="{StaticResource SettingInput}"
                             Width="50"
                             DockPanel.Dock="Right"/>
                    <Slider x:Name="TimeFontSizeSlider"
                            Style="{StaticResource SettingSlider}"
                            Value="{Binding Path=TimeFontSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            Minimum="10"
                            Maximum="40"
                            TickFrequency="1"
                            LargeChange="5"
                            ToolTip="Adjust the font size for the time display (10-40)"/>
                </DockPanel>
                <CheckBox Content="{x:Static res:Strings.Settings24HourClock}"
                        IsChecked="{Binding Path=Clock24HR, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ToolTip="{x:Static res:Strings.Settings24HourClockTooltip}"/>


            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>

